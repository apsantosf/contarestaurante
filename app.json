{
  "expo": {
    "name": "Racha Conta 🍽️",
    "slug": "contarestaurante",
    "version": "1.1.1", // 👈 Atualizado de 1.1.0 para 1.1.1
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "contarestaurante",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#E6F4FE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.apsantosf.contarestaurante"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#E6F4FE"
      },
      "package": "com.apsantosf.contarestaurante"
    },
    "plugins": ["expo-router"],
    "extra": {
      "eas": {
        "projectId": "83c58ac2-e390-4e11-aebe-e34e4a583384"
      }
    }
  }
}
